# ─────────────────────────────────────────────
#  Federated Healthcare RAG System — Env Config
# ─────────────────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to source control.

# ── Pinecone ──────────────────────────────────
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=healthcare-rag
PINECONE_ENVIRONMENT=us-east-1-aws   # e.g. gcp-starter / us-east-1-aws

# ── Embedding Model ───────────────────────────
# Dimension MUST match what your Pinecone index was created with.
# all-MiniLM-L6-v2  → 384 dims  (default, local/free)
# text-embedding-3-small → 1536 dims (OpenAI)
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
EMBEDDING_DIMENSION=384

# ── LLM Provider ─────────────────────────────
# Options: gemini | openai
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# (Only needed if LLM_PROVIDER=openai)
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# ── App Settings ──────────────────────────────
APP_ENV=development          # development | production
LOG_LEVEL=INFO
DEFAULT_TOP_K=5
MAX_TOP_K=20
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Trusted Sources (comma-separated) ─────────
# Documents whose 'source' metadata matches will get a trust boost.
TRUSTED_SOURCES=WHO,CDC,PubMed,NIH,MedlinePlus
